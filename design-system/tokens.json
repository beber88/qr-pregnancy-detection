      "critical-text": { "value": "7:1", "standard": "WCAG AAA", "description": "Result text, disclaimers" },
      "body-text": { "value": "4.5:1", "standard": "WCAG AA", "description": "All other text" },
      "disclaimer-min": { "value": "4.5:1", "standard": "WCAG AA", "description": "Disclaimer — never grey-on-grey" }
    },
    "dynamic-type": {
      "max-scale": { "value": "200%", "description": "Layout must not break at 200% text size" }
    },
    "rules": [
